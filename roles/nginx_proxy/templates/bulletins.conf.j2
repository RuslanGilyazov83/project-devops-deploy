# Кеш для статических файлов и ответов приложения
proxy_cache_path /var/cache/nginx/bulletins
    levels=1:2
    keys_zone=bulletins_cache:10m
    max_size=500m
    inactive=60m
    use_temp_path=off;

# Редирект HTTP → HTTPS
server {
    listen 80;
    server_name {{ nginx_server_name }};

    # Точка для проверки Let's Encrypt (certbot webroot)
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS-сервер
server {
    listen 443 ssl;
    server_name {{ nginx_server_name }};

    # Сертификаты Let's Encrypt
    ssl_certificate     /etc/letsencrypt/live/{{ nginx_server_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ nginx_server_name }}/privkey.pem;

    # Современные TLS-настройки (TLS 1.2 / 1.3, без устаревших шифров)
    ssl_protocols             TLSv1.2 TLSv1.3;
    ssl_ciphers               ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache         shared:SSL:10m;
    ssl_session_timeout       1d;
    ssl_session_tickets       off;

    # HSTS — принудительный HTTPS на 6 месяцев
    add_header Strict-Transport-Security "max-age=15768000" always;

    # Логи
    access_log /var/log/nginx/bulletins.access.log;
    error_log  /var/log/nginx/bulletins.error.log;

    # Максимальный размер загружаемого файла
    client_max_body_size 64m;

    # Статические файлы — кешируем на стороне клиента и в proxy_cache
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|map)$ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_cache            bulletins_cache;
        proxy_cache_valid      200 7d;
        proxy_cache_use_stale  error timeout updating http_500 http_502 http_503 http_504;
        add_header             X-Cache-Status $upstream_cache_status;

        # Браузерное кеширование статики на 7 дней
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Все остальные запросы — проксируем в приложение без кеширования
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 10s;
        proxy_read_timeout    60s;
        proxy_send_timeout    60s;
    }
}
